generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  company       Company?
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Plan {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String   @unique
  priceMonthly Int
  trialDays    Int      @default(7)
  maxLeads     Int?
  maxMembers   Int?
  features     Json     @default("[]")
  isActive     Boolean  @default(true)
  dodoPlanId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  companyId          String    @db.ObjectId @unique
  planId             String    @db.ObjectId
  trialStart         DateTime  @default(now())
  trialEnd           DateTime
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  status             String    @default("trial")
  dodoSubscriptionId String?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]
}

model Payment {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  subscriptionId   String    @db.ObjectId
  amount           Int
  currency         String    @default("INR")
  status           String
  gateway          String?
  gatewayOrderId   String?
  gatewayPaymentId String?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

model Company {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId @unique
  name           String
  email          String
  website        String?
  industry       String
  size           String?
  dodoCustomerId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  teamMembers  TeamMember[]
  leadForm     LeadForm[]
  teams        Team[]
  subscription Subscription?
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fields       BusinessField[]  
}

model TeamMember {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId       String   @db.ObjectId
  name            String
  email           String
  password        String
  role            String   @default("sales_rep")
  seniority       String   @default("junior")
  specialty       String?
  status          String   @default("active")
  leads           Int      @default(0)
  converted       Int      @default(0)
  activeLeads     Int      @default(0)
  avgResponseTime String   @default("—")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships   TeamMembership[]
  ledTeams      Team[]           @relation("TeamLead")
  assignedLeads FormSubmission[] @relation("AssignedMember")

  @@unique([companyId, email])
}

model Team {
  id          String      @id @default(auto()) @map("_id") @db.ObjectId
  companyId   String      @db.ObjectId
  name        String
  description String?
  color       String      @default("#D4622A")
  teamLeadId  String?     @db.ObjectId
  teamLead    TeamMember? @relation("TeamLead", fields: [teamLeadId], references: [id], onDelete: SetNull)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memberships TeamMembership[]

  @@unique([companyId, name])
}

model TeamMembership {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  teamId       String   @db.ObjectId
  teamMemberId String   @db.ObjectId
  joinedAt     DateTime @default(now())

  team   Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([teamId, teamMemberId])
}

model LeadForm {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId String   @db.ObjectId
  name      String   @default("Untitled Form")
  slug      String
  fields    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@unique([companyId, slug])
}

model FormSubmission {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  formId     String?   @db.ObjectId
  companyId  String    @db.ObjectId
  data       Json
  rank       String?
  rankReason String?
  rankedAt   DateTime?
  hash       String?  @db.String  
  assignedTo String?   @db.ObjectId
  assignedAt DateTime?
  calledAt   DateTime?
  callNote   String?
  status     String?   @default("new")
  createdAt  DateTime  @default(now())
    
  form           LeadForm?   @relation(fields: [formId], references: [id], onDelete: Cascade)
  assignedMember TeamMember? @relation("AssignedMember", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@index([companyId, hash])
}




model BusinessField {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId  String   @db.ObjectId
  key        String  
  label      String   
  type       String   
  options    Json?    
  isRequired Boolean  @default(false)
  isDeleted  Boolean  @default(false)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, key])
  @@index([companyId, isDeleted])
}

model FieldTemplate {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  category   String   
  key        String
  label      String
  type       String
  options    Json?
  isRequired Boolean  @default(false)
  order      Int      @default(0)

  @@unique([category, key])
  @@index([category])
}




