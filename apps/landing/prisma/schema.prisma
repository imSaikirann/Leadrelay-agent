generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  company       Company ?
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}


model Company {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId @unique
  name      String
  email     String
  website   String?
  industry  String
  size      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teamMembers TeamMember[]
  leadForm    LeadForm[]
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}



model TeamMember {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId       String   @db.ObjectId
  name            String
  email           String
  password        String   // ← hashed password
  role            String   @default("Sales Rep")
  seniority       String   @default("junior") // ← junior | mid | senior
  specialty       String?
  status          String   @default("active")
  leads           Int      @default(0)
  converted       Int      @default(0)
  activeLeads     Int      @default(0)
  avgResponseTime String   @default("—")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, email])
}




model LeadForm {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  companyId String   @db.ObjectId        // ← remove @unique
  name      String   @default("Untitled Form")  // ← form name
  slug      String                        // ← unique per form e.g. "bootcamp-leads"
  fields    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@unique([companyId, slug])  // ← slug unique per company
}

model FormSubmission {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  formId    String   @db.ObjectId
  companyId String   @db.ObjectId
  data      Json
  rank      String?  // ← "hot" | "warm" | "cold"
  rankReason String? // ← why it was ranked this way
  rankedAt  DateTime?
  createdAt DateTime @default(now())

  form LeadForm @relation(fields: [formId], references: [id], onDelete: Cascade)
}